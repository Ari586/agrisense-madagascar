// This is your Prisma schema file,
// learn more at it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  phone     String?
  region    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  diagnoses   Diagnosis[]
  smsLogs     SmsLog[]
  sensorReadings SensorReading[]
}

model Diagnosis {
  id           String   @id @default(cuid())
  userId       String?
  disease      String
  malagasyName String?
  confidence   Int
  severity     String
  symptoms     String
  treatment    String
  prevention   String
  imageUrl     String?
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model SmsLog {
  id        String   @id @default(cuid())
  userId    String?
  phone     String
  message   String
  status    String   @default("pending")
  type      String   @default("alert")
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model SensorReading {
  id          String   @id @default(cuid())
  userId      String?
  region      String?
  soilMoisture Float
  temperature  Float
  humidity    Float
  lightLevel  Float
  windSpeed   Float
  rainfall    Float
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model MarketPrice {
  id          String   @id @default(cuid())
  cropId      String   @unique // ex: "vary", "vanille"
  name        String   // ex: "Vary (Riz)"
  price       Float    // Prix actuel en MGA
  trend       String   // "up", "down", ou "stable"
  percentage  Float    // Pourcentage de variation (ex: 2.5)
  category    String   // "Renivola", "Fanondranana", etc.
  updatedAt   DateTime @updatedAt
}